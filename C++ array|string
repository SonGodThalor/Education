int main(){
	SetConsoleOutputCP(CP_UTF8);
	SetConsoleCP(CP_UTF8);

	string text = "asha uhu bela krasa bila anna sasha  aa";

	int count = 0;
	string word = "";

	for (int i = 0; i <= text.length(); i++) {
		if (i < text.length() && isalpha(text[i])) {
			word += tolower(text[i]);
		}
		else {
			if (!word.empty()) {
				if (word.front() == word.back()) {
					count++;
				}
				word.clear();
			}
		}
	}

	cout << "Количество слов: " << count << endl;

	return 0;
}
