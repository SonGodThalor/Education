	for (int i = 0; i < n; i++) {
		cout << trenches[i].name << " " << trenches[i].ocean << " " << trenches[i].type << " " << trenches[i].depth << endl;
	};
	cout << "------" << endl;
	for (int i = 0; i < 5; i++) {
		int count = 0;
		cout << "Информация по " << Oceans[i] << " Ocean" << endl;
		for (int k = 0; k < n; k++) {
			if (trenches[k].ocean == Oceans[i] && count < 3) {
