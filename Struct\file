void swal(trench &a, trench &b) {
	trench temp = a;
	a = b;
	b = temp;
}

void change_depth(trench* trenches) {
	double newdepth;
	cout << "Введите глубину, которую хотите изменить: ";
	cin >> newdepth;
	for (int i = 0; i < n; i++) {
		if (trenches[i].depth == newdepth) {
			cout << "Введите новые данные для впадины " << trenches[i].name << ": " << endl;
			cout << "Океан: ";
			cin >> trenches[i].ocean;
			cout << "Тип: ";
			cin >> trenches[i].type;
			cout << "Глубина: ";
			cin >> trenches[i].depth;
		};
	};
}
void change_depth_from_file(trench* trenches)
{
	SetConsoleOutputCP(CP_UTF8);
	SetConsoleCP(CP_UTF8);
	ifstream fin;
	double depth;
	int i = 0;
	string filename;
	cout << "Введите текстовый файл, из которого которого хотите взять данные о глубине: ";
	cin >> filename;
	fin.open(filename);
	if (fin.is_open()) {
		while (!fin.eof())
		{
			fin >> depth;
			trenches[i].depth = depth;
			i++;
		}
	}
	fin.close();
}

void saveTrenchesBinary(trench* trenches, int size, const string& filename) {
	ofstream out(filename, ios::binary | ios::out);
	if (out.is_open()) {
		out.write((char*)trenches, sizeof(trench) * size);
		out.close();
		cout << "Данные успешно сохранены в бинарный файл: " << filename << endl;
	}
}

void loadTrenchesBinary(trench* trenches, int size, const string& filename) {
	ifstream in(filename, ios::binary | ios::in);
	if (in.is_open()) {
		in.read((char*)trenches, sizeof(trench) * size);
		in.close();
		cout << "Данные успешно загружены из бинарного файла: " << filename << endl;
	}
}

void main() {
	SetConsoleOutputCP(CP_UTF8);
	SetConsoleCP(CP_UTF8);
	string Ocean;
	string binaryFilename;
	string Oceans[] = { "Pacific", "Atlantic", "Indian", "Southern", "Arctic"};
	trench oceanarr[n];
	trench* trenches = init();
	for (int i = 0; i < n; i++) {
		cout << trenches[i].name << " " << trenches[i].ocean << " " << trenches[i].type << " " << trenches[i].depth << endl;
	}
	for (int i = 0; i < n; i++) {
		for (int j = 0; j < n - 1; j++) {
			if (trenches[j].depth < trenches[j + 1].depth) {
				swal(trenches[j], trenches[j + 1]);
			}
		}
	}
	cout << "------" << endl;
	cout << "Максимальная глубина: " << trenches[0].depth << endl;
	cout << "Минимальная глубина: " << trenches[n - 1].depth << endl;
