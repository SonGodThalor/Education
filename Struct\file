				count++;
			}
		};
		cout << "-----" << endl;
	};
	cout << "------" << endl;

	change_depth(trenches);
	for (int i = 0; i < n; i++) {
		cout << trenches[i].name << " " << trenches[i].ocean << " " << trenches[i].type << " " << trenches[i].depth << endl;
	}

	cout << "------" << endl;

	cout << "Введите на какой какой океан хотите посмотреть (Pacific/Atlantic/Indian/Southern/Arctic): " << endl;
	cin >> Ocean;
	cout << "Впадины, расположенные в " << Ocean << ":" << endl;

	for (int i = 0; i < n; i++) {
		if (trenches[i].ocean == Ocean) {
			oceanarr[i] = { trenches[i].name, trenches[i].ocean, trenches[i].type, trenches[i].depth };
		};
	};
	for (int i = 0; i < n; i++) {
		if (oceanarr[i].ocean == Ocean) {
			std::cout << oceanarr[i].name << " " << oceanarr[i].ocean << " " << oceanarr[i].type << " " << oceanarr[i].depth << std::endl;
		}
	};

	cout << "------" << endl;


	change_depth_from_file(trenches);
	for (int i = 0; i < n; i++) {
		cout << trenches[i].name << " " << trenches[i].ocean << " " << trenches[i].type << " " << trenches[i].depth << endl;
	}
	cout << "Введите имя файла для сохранения данных в бинарный файл: ";
	cin >> binaryFilename;
	saveTrenchesBinary(trenches, n, binaryFilename);

	loadTrenchesBinary(trenches, n, binaryFilename);
	cout << "Данные после загрузки из бинарного файла:" << endl;
	for (int i = 0; i < n; i++) {
		cout << trenches[i].name << " " << trenches[i].ocean << " " << trenches[i].type << " " << trenches[i].depth << endl;
	}

	delete[] trenches;
}
